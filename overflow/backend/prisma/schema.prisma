generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TradeType {
  BUY
  SELL
}

enum MatchStatus {
  UPCOMING
  LIVE
  COMPLETED
}

enum FanWarStatusEnum {
  OPEN
  LOCKED
  SETTLED
  CANCELLED
}

enum PredictionPoolStatusEnum {
  OPEN
  LIVE
  SETTLED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Team {
  id               String       @id @default(uuid())
  name             String       @unique
  symbol           String       @unique
  tokenAddress     String?
  color            String
  currentPrice     Decimal      @default(0) @db.Decimal(18, 8)
  priceChange24h   Decimal      @default(0) @db.Decimal(18, 4)
  sellTaxRate      Decimal      @default(5) @db.Decimal(5, 2)
  performanceScore Decimal      @default(50) @db.Decimal(6, 2)
  ranking          Int          @default(0)
  wins             Int          @default(0)
  losses           Int          @default(0)
  nrr              Decimal      @default(0) @db.Decimal(8, 4)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  matchesAway      Match[]      @relation("AwayTeam")
  matchesHome      Match[]      @relation("HomeTeam")
  positions        Position[]
  priceHistory     PricePoint[]
  trades           Trade[]
  fanWarsHome      FanWar[]     @relation("FanWarHome")
  fanWarsAway      FanWar[]     @relation("FanWarAway")
  fanWarLocks      FanWarLock[]
}

model Match {
  id          String      @id @default(uuid())
  homeTeamId  String
  awayTeamId  String
  status      MatchStatus @default(UPCOMING)
  homeScore   String?
  awayScore   String?
  toss        String?
  venue       String?
  startTime   DateTime
  endTime     DateTime?
  winnerId    String?
  upsetScore  Int?
  isUpset     Boolean     @default(false)
  aiAnalysis  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cricApiId   String?     @unique
  cricApiName     String?
  balls           BallEvent[]
  fanWar          FanWar?
  predictionPool  PredictionPool?
  upsetEvent      UpsetEvent?
  awayTeam        Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam        Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])

  @@index([status, startTime])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model BallEvent {
  id         String   @id @default(uuid())
  matchId    String
  innings    Int
  over       Int
  ball       Int
  batter     String
  bowler     String
  runs       Int
  extras     Int      @default(0)
  isWicket   Boolean  @default(false)
  wicketType String?
  commentary String?
  timestamp  DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id])

  @@index([matchId, innings, timestamp])
}

model Trade {
  id         String    @id @default(uuid())
  teamId     String
  wallet     String
  type       TradeType
  amount     Decimal   @db.Decimal(18, 8)
  price      Decimal   @db.Decimal(18, 8)
  totalValue Decimal   @db.Decimal(18, 2)
  fee        Decimal   @db.Decimal(18, 2)
  taxRate    Decimal   @db.Decimal(5, 2)
  txHash     String?
  createdAt  DateTime  @default(now())
  team       Team      @relation(fields: [teamId], references: [id])

  @@index([wallet, createdAt])
  @@index([teamId, createdAt])
  @@index([createdAt])
  @@unique([txHash])
  @@index([wallet, teamId, type])
}

model Position {
  id          String   @id @default(uuid())
  wallet      String
  teamId      String
  amount      Decimal  @db.Decimal(18, 8)
  avgBuyPrice Decimal  @db.Decimal(18, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id])

  @@unique([wallet, teamId])
  @@index([wallet])
}

model PricePoint {
  id        String   @id @default(uuid())
  teamId    String
  price     Decimal  @db.Decimal(18, 8)
  volume    Decimal  @default(0) @db.Decimal(18, 2)
  open      Decimal  @db.Decimal(18, 8)
  high      Decimal  @db.Decimal(18, 8)
  low       Decimal  @db.Decimal(18, 8)
  close     Decimal  @db.Decimal(18, 8)
  timestamp DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])

  @@index([teamId, timestamp])
}

model UpsetEvent {
  id              String   @id @default(uuid())
  matchId         String   @unique
  winnerSymbol    String
  loserSymbol     String
  upsetScore      Int
  multiplier      Int
  vaultRelease    Decimal  @db.Decimal(18, 2)
  totalPayout     Decimal  @db.Decimal(18, 2)
  holdersCount    Int
  perHolderPayout Decimal  @db.Decimal(18, 8)
  createdAt       DateTime @default(now())
  match           Match    @relation(fields: [matchId], references: [id])
}

model VaultState {
  id        String   @id @default("vault")
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  totalIn   Decimal  @default(0) @db.Decimal(18, 2)
  totalOut  Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt DateTime @updatedAt
}

model SyncState {
  id             String   @id @default("chain-sync")
  lastBlock      Int      @default(0)
  lastSyncedAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FanWar {
  id              String           @id @default(uuid())
  matchId         String           @unique
  homeTeamId      String
  awayTeamId      String
  totalHomeLocked Decimal          @default(0) @db.Decimal(18, 2)
  totalAwayLocked Decimal          @default(0) @db.Decimal(18, 2)
  boostPool       Decimal          @default(0) @db.Decimal(18, 2)
  status          FanWarStatusEnum @default(OPEN)
  winnerTeamId    String?
  marginType      String?
  homeBoostShare  Decimal?         @db.Decimal(18, 4)
  awayBoostShare  Decimal?         @db.Decimal(18, 4)
  settledAt       DateTime?
  lockDeadline    DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  match           Match            @relation(fields: [matchId], references: [id])
  homeTeam        Team             @relation("FanWarHome", fields: [homeTeamId], references: [id])
  awayTeam        Team             @relation("FanWarAway", fields: [awayTeamId], references: [id])
  locks           FanWarLock[]

  @@index([status])
}

model FanWarLock {
  id          String    @id @default(uuid())
  fanWarId    String
  wallet      String
  teamId      String
  amount      Decimal   @db.Decimal(18, 2)
  boostReward Decimal?  @db.Decimal(18, 2)
  claimed     Boolean   @default(false)
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  fanWar      FanWar    @relation(fields: [fanWarId], references: [id])
  team        Team      @relation(fields: [teamId], references: [id])

  @@unique([fanWarId, wallet])
  @@index([wallet])
  @@index([fanWarId])
}

model PredictionPool {
  id               String    @id @default(uuid())
  matchId          String    @unique
  match            Match     @relation(fields: [matchId], references: [id])
  entryFee         Decimal   @db.Decimal(18, 8)
  totalPool        Decimal   @default(0) @db.Decimal(18, 2)
  participantCount Int                    @default(0)
  status           PredictionPoolStatusEnum @default(OPEN)
  platformShare    Decimal?  @db.Decimal(18, 2)
  safetyFloorPool  Decimal?  @db.Decimal(18, 2)
  accuracyPool     Decimal?  @db.Decimal(18, 2)
  totalScoreSum    Decimal?  @db.Decimal(18, 2)
  highestScore     Decimal?  @db.Decimal(18, 2)
  deadline         DateTime
  settledAt        DateTime?
  claimDeadline    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  questions        PredictionQuestion[]
  entries          PredictionEntry[]

  @@index([status])
}

model PredictionQuestion {
  id            String   @id @default(uuid())
  poolId        String
  pool          PredictionPool @relation(fields: [poolId], references: [id])
  questionIndex Int
  questionText  String
  options       String[]
  correctOption Int?
  points        Int
  isLive        Boolean  @default(false)
  deadline      DateTime
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  answers       PredictionAnswer[]

  @@unique([poolId, questionIndex])
}

model PredictionEntry {
  id          String    @id @default(uuid())
  poolId      String
  pool        PredictionPool @relation(fields: [poolId], references: [id])
  wallet      String
  totalScore  Decimal?  @db.Decimal(18, 2)
  payout      Decimal?  @db.Decimal(18, 2)
  claimed     Boolean   @default(false)
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  answers     PredictionAnswer[]

  @@unique([poolId, wallet])
  @@index([wallet])
}

model PredictionAnswer {
  id            String   @id @default(uuid())
  entryId       String
  entry         PredictionEntry @relation(fields: [entryId], references: [id])
  questionId    String
  question      PredictionQuestion @relation(fields: [questionId], references: [id])
  chosenOption  Int
  isCorrect     Boolean?
  pointsEarned  Decimal? @db.Decimal(18, 2)
  createdAt     DateTime @default(now())

  @@unique([entryId, questionId])
}
