# =============================================================================
# Overflow Frontend — Multi-stage Dockerfile
# Base image: node:20-alpine
#
# IMPORTANT: NEXT_PUBLIC_* variables are inlined into the JavaScript bundle
# at build time by the Next.js compiler.  They must be supplied as Docker
# build ARGs (--build-arg or the `args:` key in docker-compose.yml).
# Passing them only as runtime ENV vars will have no effect on the bundle.
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: deps
# Install production + dev dependencies using the lock file for reproducibility.
# ---------------------------------------------------------------------------
FROM node:20-alpine AS deps

RUN apk add --no-cache libc6-compat

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# ---------------------------------------------------------------------------
# Stage 2: builder
# Run `next build` with all required NEXT_PUBLIC_* vars available.
# ---------------------------------------------------------------------------
FROM node:20-alpine AS builder

RUN apk add --no-cache libc6-compat

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Disable Next.js telemetry in CI / build environments
ENV NEXT_TELEMETRY_DISABLED=1

# ---------------------------------------------------------------------------
# Build-time public environment variables.
# These are declared as ARGs so docker-compose (or docker build --build-arg)
# can inject them.  Each ARG is then promoted to ENV so Next.js sees it.
# ---------------------------------------------------------------------------
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_AI_API_URL
ARG NEXT_PUBLIC_FACTORY_ADDRESS
ARG NEXT_PUBLIC_ORACLE_ADDRESS
ARG NEXT_PUBLIC_REWARDS_ADDRESS
ARG NEXT_PUBLIC_VAULT_ADDRESS
ARG NEXT_PUBLIC_CIRCUIT_BREAKER_ADDRESS
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_AI_API_URL=$NEXT_PUBLIC_AI_API_URL
ENV NEXT_PUBLIC_FACTORY_ADDRESS=$NEXT_PUBLIC_FACTORY_ADDRESS
ENV NEXT_PUBLIC_ORACLE_ADDRESS=$NEXT_PUBLIC_ORACLE_ADDRESS
ENV NEXT_PUBLIC_REWARDS_ADDRESS=$NEXT_PUBLIC_REWARDS_ADDRESS
ENV NEXT_PUBLIC_VAULT_ADDRESS=$NEXT_PUBLIC_VAULT_ADDRESS
ENV NEXT_PUBLIC_CIRCUIT_BREAKER_ADDRESS=$NEXT_PUBLIC_CIRCUIT_BREAKER_ADDRESS
ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID

RUN npm run build

# ---------------------------------------------------------------------------
# Stage 3: runner (production image)
# Uses the .next/standalone output — no full node_modules, no source code.
# next.config.ts must set `output: "standalone"` for this to work.
# ---------------------------------------------------------------------------
FROM node:20-alpine AS runner

LABEL org.opencontainers.image.title="Overflow Frontend"
LABEL org.opencontainers.image.description="Overflow Next.js web application"

RUN apk add --no-cache wget

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root system user (mirrors the official Next.js Docker example)
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 --ingroup nodejs nextjs

# Copy static assets
COPY --from=builder /app/public ./public

# Copy the standalone server bundle (includes a trimmed node_modules)
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# Copy pre-built static chunks (.next/static) into the location the
# standalone server.js expects them
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# server.js is generated by Next.js into the standalone output directory
CMD ["node", "server.js"]
