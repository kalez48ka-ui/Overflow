# =============================================================================
# CricTrade — Environment Variables
#
# Copy this file to .env and fill in the required values before running:
#   cp .env.example .env
#
# SECURITY NOTE:
#   .env is listed in .gitignore and must never be committed to version control.
#   Rotate all secrets immediately if they are accidentally exposed.
#
# Values marked [REQUIRED] will cause the service to fail without them.
# Values marked [OPTIONAL] have safe defaults suitable for local development.
# =============================================================================


# =============================================================================
# PostgreSQL
# =============================================================================

# Database user (created automatically by the postgres container on first run)
POSTGRES_USER=crictrade

# [REQUIRED in production] Use a strong random password.
# Generate one: openssl rand -base64 32
POSTGRES_PASSWORD=crictrade_dev


# =============================================================================
# Backend — Node.js / Express
# =============================================================================

NODE_ENV=production

# Host port to expose the backend API on (maps to container port 3001)
BACKEND_PORT=3001

# Blockchain RPC endpoint for the WIRE testnet (or mainnet)
RPC_URL=https://testnet-rpc.wirefluid.com

# [REQUIRED] CricAPI key for live cricket data
# Obtain at: https://cricapi.com
CRICKET_API_KEY=

CRICKET_API_URL=https://api.cricapi.com/v1

# [REQUIRED] Private key of the oracle wallet that pushes prices on-chain.
# Must be the deployer/oracle account used when contracts were deployed.
# WARNING: never share this value — treat it like a bank password.
ORACLE_PRIVATE_KEY=

# Smart-contract addresses (deployed to RPC_URL network)
# Leave blank for local development if contracts are not yet deployed.
FACTORY_ADDRESS=
ORACLE_ADDRESS=
REWARDS_ADDRESS=
VAULT_ADDRESS=
CIRCUIT_BREAKER_ADDRESS=


# =============================================================================
# Frontend — Next.js
# =============================================================================

# Host port to expose the frontend on
FRONTEND_PORT=3000

# NEXT_PUBLIC_* variables are baked into the JavaScript bundle at build time.
# If you change these values you MUST rebuild the frontend image.

# Public-facing URLs for browser-side API calls.
# In production, these should point to your load balancer / reverse proxy.
# In local Docker development, use localhost with the host-mapped port.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_API_URL=http://localhost:5001

# WalletConnect project ID — obtain at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=


# =============================================================================
# AI Engine — Python / Flask / LangChain
# =============================================================================

# Host port to expose the AI engine on
AI_ENGINE_PORT=5001

# [REQUIRED] Anthropic API key for Claude model calls
# Obtain at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Claude model identifier to use for AI analysis
CLAUDE_MODEL=claude-sonnet-4-20250514

# Sentence-transformers model name (downloaded from HuggingFace Hub on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Python environment label (informational only)
PYTHON_ENV=production

# Flask debug mode — set to "true" only for local development
FLASK_DEBUG=false

# Log level for the AI engine (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
